# Copy this file to .env when you are ready for real OpenAI features in step 2.

OPENAI_API_KEY=
PORT=3000
OPENAI_MODEL=gpt-5.4-mini
OPENAI_CHAT_MODEL=gpt-5.4-mini
ALLOWED_ORIGINS=http://localhost:3000
MAX_REQUEST_BODY_BYTES=1000000
STORAGE_MODE=sqlite
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

RESEND_API_KEY=
RESEND_FROM="StudySpark <onboarding@resend.dev>"

# Email verification and password reset delivery.
# If these are empty during local development, the server logs verification/reset codes.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
